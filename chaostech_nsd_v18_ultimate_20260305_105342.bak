<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ChaosTech NSD v18 - AI Counter-UAS System</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#000; color:#00ff41; font-family:'Courier New',monospace; font-size:12px; height:100vh; overflow:hidden; }
.top-banner { background:#cc0000; color:#fff; text-align:center; padding:6px; font-weight:bold; font-size:13px; letter-spacing:2px; }
.sub-banner { background:#001100; color:#007700; text-align:center; padding:3px; font-size:10px; border-bottom:1px solid #00ff41; }
.layout { display:grid; grid-template-columns:1fr 320px; height:calc(100vh - 46px); }
.left { display:flex; flex-direction:column; border-right:1px solid #00ff41; }
canvas { flex:1; background:#000a00; display:block; }
.bottom { display:grid; grid-template-columns:1fr 1fr; height:160px; border-top:1px solid #00ff41; }
.panel { padding:8px; background:#000a00; border-right:1px solid #003300; overflow:hidden; }
.panel-title { color:#00ff41; font-size:11px; font-weight:bold; letter-spacing:1px; margin-bottom:6px; padding-bottom:3px; border-bottom:1px solid #003300; }
.row { display:flex; justify-content:space-between; margin:2px 0; font-size:11px; }
.row .lbl { color:#007700; }
.row .val { color:#00ff41; font-weight:bold; }
.right { background:#000a00; overflow-y:auto; display:flex; flex-direction:column; }
.sec { border-bottom:1px solid #003300; padding:10px; }
.sec-title { font-size:11px; font-weight:bold; letter-spacing:1px; color:#00ff41; margin-bottom:8px; }
.btn { background:#001a00; color:#00ff41; border:1px solid #00ff41; padding:8px; width:100%; cursor:pointer; font-family:'Courier New',monospace; font-size:11px; font-weight:bold; letter-spacing:1px; margin-bottom:6px; }
.btn:hover { background:#003300; }
.btn-active { background:#1a0000; color:#ff4444; border-color:#ff4444; }
.mode-grid { display:grid; grid-template-columns:1fr 1fr; gap:4px; }
.mbtn { background:#001a00; color:#00cc00; border:1px solid #005500; padding:6px; cursor:pointer; font-family:'Courier New',monospace; font-size:10px; font-weight:bold; }
.mbtn:hover, .mbtn.on { background:#003300; border-color:#00ff41; color:#00ff41; }
.ai-row { display:flex; align-items:center; gap:8px; font-size:11px; margin-bottom:5px; }
.ai-row label { color:#00aa00; }
input[type=checkbox] { accent-color:#00ff41; }
input[type=range] { width:100%; accent-color:#00ff41; margin-top:3px; }
.threat-card { background:#001500; border:1px solid #003300; border-left:3px solid #00ff41; padding:5px 7px; margin:3px 0; font-size:10px; }
.threat-card.hi { border-left-color:#ff4444; }
.threat-card.md { border-left-color:#ffaa00; }
@keyframes swarmPulse {
  0%,100% { opacity:1; color:#ff0000; text-shadow:0 0 20px #ff0000; }
  50%      { opacity:0.3; }
}
#swarmAlert {
  display:none; position:absolute; top:12px; left:50%;
  transform:translateX(-50%);
  color:#ff0000; font-family:monospace; font-size:13px; font-weight:bold;
  letter-spacing:3px; animation:swarmPulse 0.6s infinite;
  z-index:999; pointer-events:none;
  text-shadow:0 0 15px #ff0000;
}
.threat-card.swarm { border-left-color:#ff0000; background:#1a0000; }

@keyframes bandFlash {
  0%   { color:#00ff41; text-shadow:0 0 6px #00ff41; }
  35%  { color:#ffffff; text-shadow:0 0 20px #fff; }
  100% { color:#00ff41; text-shadow:0 0 6px #00ff41; }
}
.band-switching { animation: bandFlash 0.5s ease 3; }

.t-hdr { display:flex; justify-content:space-between; margin-bottom:2px; }
.t-id { color:#00ff41; font-weight:bold; }
.t-score { padding:1px 5px; border-radius:2px; font-weight:bold; }
.sc-hi { background:#cc0000; color:#fff; }
.sc-md { background:#ff8800; color:#000; }
.sc-lo { background:#006600; color:#fff; }
.t-data { color:#009900; }
.jam-bar { height:4px; background:#001100; border-radius:2px; margin-top:3px; }
.jam-fill { height:100%; background:#ffaa00; border-radius:2px; }
.rf-row { display:flex; align-items:center; gap:6px; margin:3px 0; font-size:10px; }
.rf-lbl { color:#007700; width:55px; }
.rf-bg { flex:1; height:8px; background:#001100; border-radius:2px; }
.rf-fill { height:100%; background:#00ff41; border-radius:2px; transition:width 0.4s; }
.rf-n { color:#00ff41; width:20px; text-align:right; }
.energy-bar { height:16px; background:#001100; border:1px solid #003300; border-radius:2px; overflow:hidden; margin-top:3px; }
.energy-fill { height:100%; background:linear-gradient(90deg,#ff0000,#ffaa00 50%,#00ff41); display:flex; align-items:center; justify-content:center; transition:width 0.5s; }
.energy-fill span { font-size:10px; font-weight:bold; color:#000; }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-thumb { background:#005500; }
</style>
</head>
<body>
<div class="top-banner">&#9651; SIMULATION MODE - DEMONSTRATION PURPOSES ONLY &#9651;</div>
<div class="sub-banner">FCC PART 15 COMPLIANT | DEFENSIVE USE ONLY | AUTHORIZED OPERATORS</div>
<div class="layout">
  <div class="left">
    <canvas id="radar"></canvas>
    <div class="bottom">
      <div class="panel">
        <div class="panel-title">&#9675; MISSION INTELLIGENCE</div>
        <div class="row"><span class="lbl">Uptime:</span><span class="val" id="uptime">0:00:00</span></div>
        <div class="row"><span class="lbl">Unique RF Sources:</span><span class="val" id="mTD">0</span></div>
        <div class="row"><span class="lbl">Threats Engaged:</span><span class="val" id="mTE">0</span></div>
        <div class="row"><span class="lbl">Threats Neutralized:</span><span class="val" id="mTN">0</span></div>
        <div class="row"><span class="lbl">Swarms Detected:</span><span class="val" id="mSD">0</span></div>
        <div class="row"><span class="lbl">Swarms Eliminated:</span><span class="val" id="mSE">0</span></div>
        <div class="row"><span class="lbl">Autonomous Actions:</span><span class="val" id="mAA">0</span></div>
      </div>
     <div class="panel">
       <div class="panel-title">&#9675; RF SPECTRUM ANALYSIS</div>
       <canvas id="rfCanvas" style="width:100%;height:130px;background:#000a00;display:block;margin-bottom:6px;"></canvas>
       <div class="rf-row"><span class="rf-lbl">0.43 GHz:</span><div class="rf-bg"><div class="rf-fill" id="rfb1" style="width:0%"></div></div><span class="rf-n" id="rfc1">0</span></div>
       <div class="rf-row"><span class="rf-lbl">0.90 GHz:</span><div class="rf-bg"><div class="rf-fill" id="rfb2" style="width:0%"></div></div><span class="rf-n" id="rfc2">0</span></div>
       <div class="rf-row"><span class="rf-lbl">2.40 GHz:</span><div class="rf-bg"><div class="rf-fill" id="rfb3" style="width:0%"></div></div><span class="rf-n" id="rfc3">0</span></div>
       <div class="rf-row"><span class="rf-lbl">Other:</span><div class="rf-bg"><div class="rf-fill" id="rfb4" style="width:0%"></div></div><span class="rf-n" id="rfc4">0</span></div>
     </div>
    </div>
  </div>
  <div class="right">
    <div class="sec">
      <div class="sec-title">SYSTEM STATUS</div>
      <div class="row"><span class="lbl">Mode:</span><span class="val" id="sMode">STANDBY</span></div>
      <div class="row"><span class="lbl">Disruption Mode:</span><span class="val" id="sDisrupt">RF_JAM</span></div>
      <div class="row"><span class="lbl">Power Level:</span><span class="val" id="sPower">100%</span></div>
      <div class="row"><span class="lbl">Energy Reserves:</span></div>
      <div class="energy-bar"><div class="energy-fill" id="eBar" style="width:100%"><span>100%</span></div></div>
    </div>
    <div class="sec">
      <div class="sec-title">SYSTEM CONTROL</div>
      <button class="btn" id="toggleBtn" onclick="toggleSystem()">ACTIVATE SYSTEM</button>
      <div style="color:#007700;font-size:10px;margin-bottom:5px;">Disruption Mode:</div>
      <div class="mode-grid">
        <button class="mbtn on" onclick="setMode('RF_JAM',this)">RF JAMMING</button>
        <button class="mbtn" onclick="setMode('GPS_SPOOF',this)">GPS SPOOF</button>
        <button class="mbtn" onclick="setMode('PROTOCOL',this)">PROTOCOL</button>
        <button class="mbtn" onclick="setMode('SWARM_DISRUPT',this)">SWARM DISRUPT</button>
      </div>
    </div>
    <div class="sec">
      <div class="sec-title">&#9670; AUTONOMOUS AI CONTROL</div>
      <div class="ai-row"><input type="checkbox" id="aiEn" onchange="updateAutonomous()"><label for="aiEn">Enable Autonomous Mode</label></div>
      <div class="ai-row"><input type="checkbox" id="aiAuto" onchange="updateAutonomous()"><label for="aiAuto">Auto-Engage Threats</label></div>
      <div style="font-size:11px;color:#007700;">Threat Threshold: <span id="thrVal">70</span></div>
      <input type="range" id="thrSlider" min="0" max="100" value="70" oninput="updateAutonomous(); document.getElementById('thrLabel').textContent=this.value;"><span id="thrLabel" style="color:#00ff41;margin-left:6px;font-size:11px;">70</span>
    </div>
    <div class="sec" style="flex:1;overflow:hidden;display:flex;flex-direction:column;">
      <div class="sec-title">ACTIVE THREATS (<span id="tCount">0</span>) <span id="activeBand" style="color:#00ff41;font-size:10px;margin-left:8px;">◉ SCANNING...</span></div>
      <div id="noiseFloor">Noise floor: -- dB</div>
      <div id="tList" style="overflow-y:auto;flex:1;"></div>
    </div>
  </div>
</div>
<script>
var API_BASE = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
  ? 'http://localhost:8000'
  : 'https://nsd.chaostechdefensellc.com';
      var RF_BASE  = 'http://localhost:8000';
var RF_Base = 'http://localhost:8000';
var _prevBand = null;
var threats = [], systemState = {}, missionState = {}, autonomousMode = {}, rfSpectrum = {};
var NSD_TOKEN = "";
// Fetch token from local API on load — never hardcoded
fetch('http://localhost:8000/api/token')
  .then(function(r){ return r.json(); })
  .then(function(d){ NSD_TOKEN = d.token || ""; })
  .catch(function(){ console.warn('Token fetch failed — POST endpoints will reject'); });
var noiseFloorDb = null, activeBandName = "";
var _autonomousDirty = 0;  // timestamp of last user interaction
var systemActive = false, currentMode = 'RF_JAM';

var canvas = document.getElementById('radar');
var ctx = canvas.getContext('2d');
var sweep = 0;

function resize() {
  var left = canvas.parentElement;
  var bottom = left.querySelector('.bottom');
  canvas.width = left.clientWidth;
  canvas.height = left.clientHeight - bottom.offsetHeight;
}
window.addEventListener('resize', resize);
resize();

function drawRadar() {
  var W = canvas.width, H = canvas.height;
  var cx = W/2, cy = H/2;
  var R = Math.min(W,H) * 0.44;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#000a00';
  ctx.fillRect(0,0,W,H);
  for (var i=1; i<=4; i++) {
    var r = (R/4)*i;
    ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
    ctx.strokeStyle = 'rgba(0,80,0,0.5)'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='#004400'; ctx.font='10px Courier New';
    ctx.fillText(((i/4)*2.5).toFixed(1)+'km', cx+r+3, cy+4);
  }
  ctx.strokeStyle='rgba(0,60,0,0.5)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(cx,cy-R); ctx.lineTo(cx,cy+R); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx-R,cy); ctx.lineTo(cx+R,cy); ctx.stroke();
  sweep = (sweep+0.025) % (Math.PI*2);
  ctx.save(); ctx.translate(cx,cy); ctx.rotate(sweep);
  var g = ctx.createLinearGradient(0,0,R,0);
  g.addColorStop(0,'rgba(0,255,65,0.5)'); g.addColorStop(1,'rgba(0,255,65,0)');
  ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,R,-0.25,0); ctx.closePath();
  ctx.fillStyle=g; ctx.fill();
  ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(R,0);
  ctx.strokeStyle='rgba(0,255,65,0.9)'; ctx.lineWidth=2; ctx.stroke();
  ctx.restore();
  ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2); ctx.fillStyle='#ff4444'; ctx.fill();
  threats.forEach(function(t) {
    var a = (t.bearing||0)*Math.PI/180;
    var pr = (Math.min(t.range||0.5,2.5)/2.5)*R;
    var px = cx+Math.sin(a)*pr, py = cy-Math.cos(a)*pr;
    var sc = t.threat_score||50;
    var BAND_COLORS = {'433MHz':'#FFD700','900MHz':'#FF4444','ADS-B':'#00FF41','2.4GHz':'#00BFFF','UNK':'#FFA500'};
    var STATE_COLORS = {'NEUTRALIZED':'#ff0000','ENGAGED':'#ffaa00','DETECTED':'#00ff41'};
    var col = STATE_COLORS[t.state] || BAND_COLORS[t.band] || (sc>70?'#ff4444':sc>40?'#ffaa00':'#00ff41');
    ctx.beginPath(); ctx.arc(px,py,9,0,Math.PI*2);
    ctx.strokeStyle=col; ctx.lineWidth=0.5; ctx.stroke();
    ctx.beginPath(); ctx.arc(px,py,5,0,Math.PI*2);
    ctx.fillStyle=col; ctx.fill();
    ctx.fillStyle='#00ff41'; ctx.font='bold 9px Courier New';
    ctx.fillText(t.id, px+7, py-2);
  });
  requestAnimationFrame(drawRadar);
}
drawRadar();

// ── Live RF Spectrum (NSD RF Bridge) ─────────────────────────
let rfFetching = false;

function drawSpectrum(freqs, powers, peaks) {
  var canvas = document.getElementById('rfCanvas');
  if (!canvas) return;

  // HiDPI sharp rendering
  var rect  = canvas.getBoundingClientRect();
  var dpr   = window.devicePixelRatio || 1;
  var W     = Math.floor(rect.width  * dpr);
  var H     = Math.floor(rect.height * dpr);
  if (canvas.width !== W || canvas.height !== H) {
    canvas.width  = W;
    canvas.height = H;
  }
  var ctx = canvas.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  var CW = rect.width, CH = rect.height;

  ctx.clearRect(0, 0, CW, CH);
  ctx.fillStyle = '#000d00';
  ctx.fillRect(0, 0, CW, CH);
  if (!freqs || freqs.length === 0) return;

  var pad = {l:42, r:12, t:10, b:22};
  var gW = CW - pad.l - pad.r;
  var gH = CH - pad.t - pad.b;
  var minFreq = freqs[0], maxFreq = freqs[freqs.length-1];

  // Downsample to max 512 points for clean rendering
  var step = Math.max(1, Math.floor(freqs.length / 512));
  var sf = [], sp = [];
  for (var i = 0; i < freqs.length; i += step) { sf.push(freqs[i]); sp.push(powers[i]); }

  // 5-point smoothing
  var sm = sp.slice();
  for (var i = 2; i < sp.length-2; i++)
    sm[i] = (sp[i-2]+sp[i-1]+sp[i]+sp[i+1]+sp[i+2]) / 5;

  // Dynamic range
  var sorted    = sm.slice().sort(function(a,b){return a-b;});
  var noiseFloor = sorted[Math.floor(sorted.length * 0.15)];
  var maxPow    = sorted[sorted.length - 1];
  var dynRange  = Math.max(maxPow - noiseFloor, 20);
  var dispMin   = noiseFloor - 3;
  var dispMax   = noiseFloor + dynRange + 6;

  function toX(f) { return pad.l + ((f-minFreq)/(maxFreq-minFreq||1))*gW; }
  function toY(p) { return pad.t + gH - Math.min(gH, Math.max(0,((p-dispMin)/(dispMax-dispMin))*gH)); }

  // Grid
  ctx.strokeStyle = 'rgba(0,140,0,0.3)';
  ctx.lineWidth   = 0.5;
  for (var g = 0; g <= 4; g++) {
    var gy = pad.t + (gH/4)*g;
    ctx.beginPath(); ctx.moveTo(pad.l, gy); ctx.lineTo(CW-pad.r, gy); ctx.stroke();
    var gv = dispMax - ((dispMax-dispMin)/4)*g;
    ctx.fillStyle = 'rgba(0,200,0,0.8)';
    ctx.font = 'bold 9px Courier New';
    ctx.textAlign = 'right';
    ctx.fillText(gv.toFixed(0)+'dB', pad.l-4, gy+3);
  }

  // Freq labels (3 evenly spaced)
  ctx.fillStyle = 'rgba(0,200,0,0.7)';
  ctx.font = '8px Courier New';
  ctx.textAlign = 'center';
  for (var lx = 0; lx <= 2; lx++) {
    var lf = minFreq + (maxFreq - minFreq) * lx / 2;
    ctx.fillText(lf.toFixed(1), pad.l + gW * lx / 2, CH - 4);
  }

  // Noise floor dashed line
  var nfY = toY(noiseFloor);
  ctx.strokeStyle = 'rgba(255,200,0,0.5)';
  ctx.lineWidth = 1;
  ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.moveTo(pad.l, nfY); ctx.lineTo(CW-pad.r, nfY); ctx.stroke();
  ctx.setLineDash([]);

  // Spectrum fill
  ctx.beginPath();
  ctx.moveTo(toX(sf[0]), toY(sm[0]));
  for (var i = 1; i < sf.length; i++) ctx.lineTo(toX(sf[i]), toY(sm[i]));
  ctx.strokeStyle = '#00ff41';
  ctx.lineWidth   = 1.5;
  ctx.stroke();
  ctx.lineTo(toX(sf[sf.length-1]), CH-pad.b);
  ctx.lineTo(toX(sf[0]),           CH-pad.b);
  ctx.closePath();
  var grad = ctx.createLinearGradient(0, pad.t, 0, CH-pad.b);
  grad.addColorStop(0, 'rgba(0,255,65,0.4)');
  grad.addColorStop(1, 'rgba(0,255,65,0.02)');
  ctx.fillStyle = grad;
  ctx.fill();

  // Peak markers — clean red mushrooms
  if (peaks && peaks.length) {
    peaks.forEach(function(pk) {
      var px = toX(pk.freq_mhz);
      var py = toY(pk.power_db);
      if (px < pad.l || px > CW-pad.r) return;
      ctx.beginPath();
      ctx.arc(px, py, 3.5, 0, Math.PI*2);
      ctx.fillStyle   = '#ff4444';
      ctx.strokeStyle = '#ff0000';
      ctx.lineWidth   = 1;
      ctx.fill(); ctx.stroke();
      // Stem
      ctx.beginPath();
      ctx.moveTo(px, py+3.5);
      ctx.lineTo(px, CH-pad.b);
      ctx.strokeStyle = 'rgba(255,60,60,0.25)';
      ctx.lineWidth   = 0.8;
      ctx.stroke();
    });
  }

  // Peak markers — circle + vertical line + freq label
  peaks.forEach(function(pk) {
    var px = toX(pk.freq_mhz);
    var py = toY(pk.power_db);
    if (py < pad.t || py > H-pad.b) return;
    ctx.strokeStyle = 'rgba(255,60,60,0.6)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(px, py); ctx.lineTo(px, H-pad.b); ctx.stroke();
    ctx.beginPath(); ctx.arc(px, py, 4, 0, Math.PI*2);
    ctx.fillStyle = '#ff3c3c'; ctx.fill();
    ctx.strokeStyle = '#ff6666'; ctx.lineWidth = 1; ctx.stroke();
  });

  // Freq axis labels
  ctx.fillStyle = 'rgba(0,200,0,0.8)';
  ctx.font = '8px Courier New';
  ctx.textAlign = 'center';
  for (var k = 0; k <= 4; k++) {
    var fv = minFreq + ((maxFreq-minFreq)/4)*k;
    ctx.fillText(fv.toFixed(1), toX(fv), H-2);
  }
}

function fetchRF() {
  fetch(RF_BASE + '/api/psd_scan')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.points || data.points.length === 0) return;
      var freqs  = data.points.map(function(p) { return p.freq_mhz; });
      var powers = data.points.map(function(p) { return p.power_db; });
      drawSpectrum(freqs, powers, data.peaks || []);
    })
    .catch(function(e) { console.warn('RF fetch:', e.message); });
}

setInterval(fetchRF, 2000);
fetchRF();

function fetchData() {
  fetch(API_BASE+'/api/hardware')
    .then(function(r){ return r.json(); })
    .then(function(d) {
      var _newThreats = (d.threats||[]).map(function(t) {
        if (t.frequency && !t.freq) {
          t.freq = parseFloat(t.frequency.split(' ')[0]) / 1000;
        }
        t.freq = t.freq || 0;
        t.speed = t.speed || (Math.floor(Math.random()*15)+10);
        t.altitude = t.altitude || (Math.floor(Math.random()*100)+50);
        return t;
      });
      if (_newThreats.length > 0) threats = _newThreats;
      systemState = d.system_state || {};
      noiseFloorDb = (d.noise_floor_db !== undefined && d.noise_floor_db !== null) ? d.noise_floor_db : noiseFloorDb;
      activeBandName = d.active_band || null;
      if (activeBandName && _prevBand && activeBandName !== _prevBand) {
        var el = document.getElementById('tCount');
        if (el) {
          el.classList.remove('band-switching');
          void el.offsetWidth;
          el.classList.add('band-switching');
          setTimeout(function(){ el.classList.remove('band-switching'); }, 1600);
        }
      }
      _prevBand = activeBandName;
      missionState = d.mission_state || {};
      autonomousMode = d.autonomous_mode || {};
      rfSpectrum = d.rf_spectrum || {};
      systemActive = systemState.active || false;
      currentMode = systemState.mode || 'RF_JAM';
      updateUI();
    })
    .catch(function(e){ console.warn('Bridge offline:', e.message); });
}

function toggleSystem() {
  systemActive = !systemActive;
  updateUI();  // instant visual feedback
  fetch(API_BASE+'/api/control', {
    method:'POST',
    headers:{'Content-Type':'application/json','X-NSD-Token':NSD_TOKEN},
    body:JSON.stringify({active:systemActive})
  }).catch(function(){});
  fetchData();
}

function setMode(mode, el) {
  currentMode = mode;
  document.querySelectorAll('.mbtn').forEach(function(b){ b.classList.remove('on'); });
  if (el) el.classList.add('on');
  document.getElementById('sDisrupt').textContent = mode;
  currentMode = mode;
  document.querySelectorAll('.mbtn').forEach(function(b){ b.classList.remove('on'); });
  if (el) el.classList.add('on');
  fetch(API_BASE+'/api/control', {
    method:'POST',
    headers:{'Content-Type':'application/json','X-NSD-Token':NSD_TOKEN},
    body:JSON.stringify({mode:mode})
  }).catch(function(){});
  
}

function updateAutonomous() {
  _autonomousDirty = Date.now();
  var en = document.getElementById('aiEn').checked;
  var au = document.getElementById('aiAuto').checked;
  var th = parseInt(document.getElementById('thrSlider').value);
  document.getElementById('thrVal').textContent = th;
  fetch(API_BASE+'/api/control', {
    method:'POST',
    headers:{'Content-Type':'application/json','X-NSD-Token':NSD_TOKEN},
    body:JSON.stringify({autonomous_enabled:en,auto_engage:au,threat_threshold:th})
  }).catch(function(){});
}

function fmtTime(s) {
  s = s||0;
  return Math.floor(s/3600)+':'+String(Math.floor((s%3600)/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');
}

function updateUI() {
  document.getElementById('sMode').textContent = systemActive ? 'ACTIVE' : 'STANDBY';
  document.getElementById('sDisrupt').textContent = currentMode;
  var pwr = systemState.power_level||100;
  document.getElementById('sPower').textContent = pwr+'%';
  var nrg = systemState.energy_reserves||100;
  document.getElementById('eBar').style.width = nrg+'%';
  document.getElementById('eBar').innerHTML = '<span>'+nrg+'%</span>';
  var btn = document.getElementById('toggleBtn');
  btn.textContent = systemActive ? 'DEACTIVATE SYSTEM' : 'ACTIVATE SYSTEM';
  btn.className = systemActive ? 'btn btn-active' : 'btn';
  if (autonomousMode.enabled !== undefined) {
    if (Date.now() - _autonomousDirty > 5000) document.getElementById('aiEn').checked = autonomousMode.enabled;
    if (Date.now() - _autonomousDirty > 5000) document.getElementById('aiAuto').checked = autonomousMode.auto_engage||false;
    var th = autonomousMode.threat_threshold||70;
    if (Date.now() - _autonomousDirty > 5000) {
      document.getElementById('thrSlider').value = th;
      var lbl = document.getElementById('thrLabel');
      if (lbl) lbl.textContent = th;
    }
    document.getElementById('thrVal').textContent = th;
  }
  var ms = missionState || {};
  // Uptime: client-side timer only (see _pageStart setInterval above)
  // Unique RF Sources
  document.getElementById('mTD').textContent = ms.threats_detected || threats.length || 0;
  // Threats Engaged = threats with score >= 70
  var engaged = threats.filter(function(t){ return (t.threat_score||0) >= 70; }).length;
  document.getElementById('mTE').textContent = engaged;
  // Swarms
  document.getElementById('mSE').textContent = ms.swarms_eliminated || 0;
  document.getElementById('mTE').textContent = ms.threats_engaged||0;
  document.getElementById('mTN').textContent = ms.threats_neutralized||0;
  
  // Swarm alert
  var ms2 = missionState || {};
  var activeSwarms = ms2.active_swarms || 0;
  var swarmEl = document.getElementById('swarmAlert');
  if (swarmEl) swarmEl.style.display = activeSwarms > 0 ? 'block' : 'none';
  document.getElementById('mSD').textContent = ms2.swarms_detected || 0;

  // legacy fallback
  // document.getElementById('mSD').textContent = ms.swarms_detected||0;
  document.getElementById('mSE').textContent = ms.swarms_eliminated||0;
  document.getElementById('mAA').textContent = ms.autonomous_actions||0;
  var bands = (rfSpectrum&&rfSpectrum.bands)?rfSpectrum.bands:{};
  var tot = Math.max(rfSpectrum.total||1,1);
  var sets = [['rfb1','rfc1',bands['433']||0],['rfb2','rfc2',bands['900']||0],['rfb3','rfc3',bands['2.4']||0],['rfb4','rfc4',bands['other']||0]];
  sets.forEach(function(s){ document.getElementById(s[0]).style.width=Math.round((s[2]/tot)*100)+'%'; document.getElementById(s[1]).textContent=s[2]; });
  var nfEl = document.getElementById('noiseFloor');
  if (nfEl) nfEl.textContent = 'Noise floor: ' + (noiseFloorDb !== null ? noiseFloorDb.toFixed(1) : '--') + ' dB';
  var abEl = document.getElementById('activeBand');
  if (abEl && activeBandName) abEl.textContent = '◉ SCANNING: ' + activeBandName;
  document.getElementById('tCount').textContent = threats.length;
  document.getElementById('tList').innerHTML = threats.map(function(t) {
    var sc  = t.threat_score||0;
    var cls = sc>70?'hi':sc>40?'md':'';
    var scCls = sc>70?'sc-hi':sc>40?'sc-md':'sc-lo';
    var state = t.state||'DETECTED';
    var stateColor = state==='NEUTRALIZED'?'#ff4444':state==='ENGAGED'?'#ffaa00':'#00ff41';
    var stateIcon  = state==='NEUTRALIZED'?'[NEUTRALIZED]':state==='ENGAGED'?'[ENGAGED]':t.swarm_member?'[SWARM]':'[DETECTED]';
    var barW = Math.min(100, sc);
    var barColor = sc>70?'#ff4444':sc>40?'#ffaa00':'#00ff41';
    return '<div class="threat-card '+cls+'" style="border-left:3px solid '+stateColor+';margin-bottom:6px;padding:6px 8px;">'
      + '<div class="t-hdr"><span class="t-id" style="color:'+stateColor+';">TGT-'+t.id+' '+(t.type||'RF')+'</span>'
      + '<span class="t-score '+scCls+'" style="color:'+stateColor+';">'+sc+'</span></div>'
      + '<div class="t-data" style="color:#aaffaa;">'+t.freq_mhz.toFixed(3)+' MHz | '+t.power_db.toFixed(1)+' dBm | '+t.band+'</div>'
      + '<div class="t-data" style="color:#ffff00;font-size:10px;">'+(t.protocol||t.type)+' — '+(t.confidence||0)+'% confidence</div>'
      + '<div class="t-data" style="color:#888;font-size:9px;font-style:italic;">'+(t.description||'')+'</div>'
      + '<div class="t-data" style="color:'+stateColor+';font-weight:bold;">'+stateIcon+'</div>'
      + '<div style="background:#001a00;border-radius:2px;height:4px;margin-top:4px;">'
      + '<div style="width:'+barW+'%;height:4px;background:'+barColor+';border-radius:2px;transition:width 0.5s;"></div></div>'
      + '</div>';
  }).join('');
}

// PROTOTYPE: NSD RF spectrum updater

async function fetchPsd(centerMhz, spanMhz) {
  centerMhz = centerMhz || 1090.0;
  spanMhz   = spanMhz   || 2.0;
  var url = API_PSD + '/api/psd_scan?center_mhz=' + centerMhz + '&span_mhz=' + spanMhz;
  var resp = await fetch(url);
  if (!resp.ok) throw new Error('PSD API error: ' + resp.status);
  return await resp.json();
}

async function updateSpectrum() {
  try {
    var data = await fetchPsd(1090.0, 2.0);
    var freqs  = data.points.map(function(p){ return p.freq_mhz; });
    var powers = data.points.map(function(p){ return p.power_db; });
    var peaks  = data.peaks;

    drawSpectrum(freqs, powers, peaks);

    var nfEl = document.getElementById('noiseFloor');
    if (nfEl) {
      nfEl.textContent = 'Noise floor: ' + (data.noise_floor_db != null ? data.noise_floor_db.toFixed(1) : '--') + ' dB';
    }
    var abEl = document.getElementById("activeBand");
    if (abEl && data.active_band) {
      abEl.textContent = "◉ SCANNING: " + data.active_band;
    }

    // Inject real peak count into threat count area if bridge is offline
    document.getElementById('tCount').textContent = peaks.length;

  } catch (err) {
    console.error('PSD update failed:', err.message);
  }
}

setInterval(updateSpectrum, 5000);
updateSpectrum();

fetchData();

var _pageStart = Date.now();
setInterval(function() {
  var elapsed = Math.floor((Date.now() - _pageStart) / 1000);
  var h = Math.floor(elapsed / 3600);
  var m = Math.floor((elapsed % 3600) / 60);
  var s = elapsed % 60;
  var fmt = h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
  var el = document.getElementById('uptime');
  if (el) el.textContent = fmt;
}, 1000);

setInterval(fetchData, 2000);
  // immediate call on load — mirrors fetchRF pattern
  // immediate call on load — mirrors fetchRF pattern
</script>

<script>
// ── NSD v19 Live Spectrum Analyzer ──────────────────────────
const SPECTRUM_API = "https://nsd.chaostechdefensellc.com/api/spectrum";
const specCanvas = document.getElementById("rfCanvas");
const specCtx = specCanvas ? specCanvas.getContext("2d") : null;

// ── NSD v19 Peak Markers ───────────────────────────────


function drawSpectrumWithPeaks(dbValues, centerMhz, spanMhz) {
    if (!specCanvas || !specCtx) return;
    const W = specCanvas.width;
    const H = specCanvas.height;
    const len = dbValues.length;
    if (!len) return;
    let minDb = Math.min(...dbValues);
    let maxDb = Math.max(...dbValues);
    specCtx.clearRect(0, 0, W, H);

    // Grid
    specCtx.strokeStyle = "rgba(0,255,102,0.2)";
    specCtx.lineWidth = 1;
    specCtx.beginPath();
    for (let d = -100; d <= -60; d += 10) {
        const y = H * (1 - (d - minDb) / (maxDb - minDb));
        specCtx.moveTo(0, y);
        specCtx.lineTo(W, y);
    }
    specCtx.stroke();

    // Waveform fill
    specCtx.beginPath();
    for (let i = 0; i < len; i++) {
        const x = (i / (len - 1)) * W;
        const norm = (dbValues[i] - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;
        if (i === 0) specCtx.moveTo(x, y);
        else specCtx.lineTo(x, y);
    }
    specCtx.lineTo(W, H);
    specCtx.lineTo(0, H);
    specCtx.closePath();
    specCtx.fillStyle = "rgba(0,255,102,0.6)";
    specCtx.fill();

    // Peaks (threshold -12dB)
    const threshold = maxDb - 12;
    const peaks = [];
    for (let i = 1; i < len - 1; i++) {
        const v = dbValues[i];
        if (v > threshold && v >= dbValues[i-1] && v >= dbValues[i+1]) {
            peaks.push({ idx: i, val: v });
        }
    }

    // Draw brighter markers
    specCtx.fillStyle = "#ffff00";
    specCtx.strokeStyle = "#ffaa00";
    specCtx.font = "bold 11px monospace";
    specCtx.shadowColor = "#ffff00";
    specCtx.shadowBlur = 4;

    const startMhz = centerMhz - spanMhz / 2;
    const hzPerBin = spanMhz / Math.max(len - 1, 1);

    peaks.forEach(p => {
        const x = (p.idx / (len - 1)) * W;
        const norm = (p.val - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;

        // Big triangle
        specCtx.beginPath();
        specCtx.moveTo(x, y - 10);
        specCtx.lineTo(x - 8, y + 2);
        specCtx.lineTo(x + 8, y + 2);
        specCtx.closePath();
        specCtx.fill();
        specCtx.stroke();

        // Freq label
        const f = startMhz + p.idx * hzPerBin;
        const label = f.toFixed(1) + "M";
        specCtx.fillText(label, Math.max(x - 25, 5), y - 15);
    });
}
(dbValues, centerMhz, spanMhz) {
    if (!specCanvas || !specCtx) return;
    const W = specCanvas.width;
    const H = specCanvas.height;
    const len = dbValues.length;
    if (!len) return;
    let minDb = Math.min(...dbValues);
    let maxDb = Math.max(...dbValues);
    specCtx.clearRect(0, 0, W, H);

    // Grid
    specCtx.strokeStyle = "rgba(0,255,102,0.2)";
    specCtx.lineWidth = 1;
    specCtx.beginPath();
    for (let d = -100; d <= -60; d += 10) {
        const y = H * (1 - (d - minDb) / (maxDb - minDb));
        specCtx.moveTo(0, y);
        specCtx.lineTo(W, y);
    }
    specCtx.stroke();

    // Waveform fill
    specCtx.beginPath();
    for (let i = 0; i < len; i++) {
        const x = (i / (len - 1)) * W;
        const norm = (dbValues[i] - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;
        if (i === 0) specCtx.moveTo(x, y);
        else specCtx.lineTo(x, y);
    }
    specCtx.lineTo(W, H);
    specCtx.lineTo(0, H);
    specCtx.closePath();
    specCtx.fillStyle = "rgba(0,255,102,0.6)";
    specCtx.fill();

    // Peaks (threshold -12dB)
    const threshold = maxDb - 12;
    const peaks = [];
    for (let i = 1; i < len - 1; i++) {
        const v = dbValues[i];
        if (v > threshold && v >= dbValues[i-1] && v >= dbValues[i+1]) {
            peaks.push({ idx: i, val: v });
        }
    }

    // Draw brighter markers
    specCtx.fillStyle = "#ffff00";
    specCtx.strokeStyle = "#ffaa00";
    specCtx.font = "bold 11px monospace";
    specCtx.shadowColor = "#ffff00";
    specCtx.shadowBlur = 4;

    const startMhz = centerMhz - spanMhz / 2;
    const hzPerBin = spanMhz / Math.max(len - 1, 1);

    peaks.forEach(p => {
        const x = (p.idx / (len - 1)) * W;
        const norm = (p.val - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;

        // Big triangle
        specCtx.beginPath();
        specCtx.moveTo(x, y - 10);
        specCtx.lineTo(x - 8, y + 2);
        specCtx.lineTo(x + 8, y + 2);
        specCtx.closePath();
        specCtx.fill();
        specCtx.stroke();

        // Freq label
        const f = startMhz + p.idx * hzPerBin;
        const label = f.toFixed(1) + "M";
        specCtx.fillText(label, Math.max(x - 25, 5), y - 15);
    });
}
(dbValues, centerMhz, spanMhz) {
    if (!specCanvas || !specCtx) return;

    const W = specCanvas.width;
    const H = specCanvas.height;
    const len = dbValues.length;
    if (!len) return;

    let minDb = Math.min(...dbValues);
    let maxDb = Math.max(...dbValues);

    specCtx.clearRect(0, 0, W, H);

    // Baseline fill
    specCtx.beginPath();
    for (let i = 0; i < len; i++) {
        const x = (i / (len - 1)) * W;
        const norm = (dbValues[i] - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;
        if (i === 0) specCtx.moveTo(x, y);
        else specCtx.lineTo(x, y);
    }
    specCtx.lineTo(W, H);
    specCtx.lineTo(0, H);
    specCtx.closePath();
    specCtx.fillStyle = "#00ff66";
    specCtx.fill();

    // Peak detection
    const threshold = maxDb - 12;  // Lowered for quieter environments  // ~6 dB below strongest signal
    const peaks = [];
    for (let i = 1; i < len - 1; i++) {
        const v = dbValues[i];
        if (v > threshold && v >= dbValues[i-1] && v >= dbValues[i+1]) {
            peaks.push({ idx: i, val: v });
        }
    }

    // Draw markers
    specCtx.fillStyle = "#ffcc00";
    specCtx.strokeStyle = "#ffcc00";
    specCtx.font = "10px monospace";

    const startMhz = centerMhz - spanMhz / 2;
    const hzPerBin = spanMhz / Math.max(len - 1, 1);

    peaks.forEach(p => {
        const x = (p.idx / (len - 1)) * W;
        const norm = (p.val - minDb) / (maxDb - minDb + 1e-6);
        const y = H - norm * H;

        // Triangle marker
        specCtx.beginPath();
        specCtx.moveTo(x, y - 6);
        specCtx.lineTo(x - 4, y);
        specCtx.lineTo(x + 4, y);
        specCtx.closePath();
        specCtx.fill();

        // Frequency label
        const f = startMhz + p.idx * hzPerBin;
        const label = f.toFixed(2) + " MHz";
        specCtx.fillText(label, Math.min(Math.max(x - 20, 0), W - 60), y - 10);
    });
}


async function fetchSpectrum() {
    if (!specCtx) return;
    try {
        const resp = await fetch(SPECTRUM_API);
        const data = await resp.json();

        if (!data.spectrum_db || data.spectrum_db.length === 0) return;
        drawSpectrumWithPeaks(data.spectrum_db, data.center_freq_mhz, data.span_mhz);
    } catch(e) {}
}

function drawSpectrum(dbValues, centerMhz, spanMhz) {
    const W = specCanvas.width;
    const H = specCanvas.height;
    const minDb = -120, maxDb = -60;
    
    // Background
    specCtx.fillStyle = "#0a0f1a";
    specCtx.fillRect(0, 0, W, H);
    
    // Grid lines
    specCtx.strokeStyle = "rgba(0,255,100,0.1)";
    specCtx.lineWidth = 1;
    for (let i = 0; i <= 6; i++) {
        const y = (i / 6) * H;
        specCtx.beginPath();
        specCtx.moveTo(0, y); specCtx.lineTo(W, y);
        specCtx.stroke();
        const dbLabel = Math.round(maxDb - ((maxDb - minDb) * i / 6));
        specCtx.fillStyle = "rgba(0,255,100,0.5)";
        specCtx.font = "10px monospace";
        specCtx.fillText(dbLabel + "dB", 2, y - 2);
    }
    
    // Frequency labels
    const startMhz = centerMhz - spanMhz / 2;
    const endMhz = centerMhz + spanMhz / 2;
    specCtx.fillStyle = "rgba(0,255,100,0.5)";
    specCtx.font = "10px monospace";
    specCtx.fillText(startMhz.toFixed(2) + "MHz", 2, H - 4);
    specCtx.fillText(centerMhz.toFixed(2) + "MHz", W/2 - 25, H - 4);
    specCtx.fillText(endMhz.toFixed(2) + "MHz", W - 70, H - 4);
    
    // Spectrum fill
    const grad = specCtx.createLinearGradient(0, 0, 0, H);
    grad.addColorStop(0, "rgba(255,50,50,0.9)");
    grad.addColorStop(0.4, "rgba(0,255,100,0.7)");
    grad.addColorStop(1, "rgba(0,255,100,0.1)");
    specCtx.fillStyle = grad;
    specCtx.beginPath();
    specCtx.moveTo(0, H);
    dbValues.forEach((db, i) => {
        const x = (i / dbValues.length) * W;
        const y = H - ((Math.min(Math.max(db, minDb), maxDb) - minDb) / (maxDb - minDb)) * H;
        i === 0 ? specCtx.moveTo(x, y) : specCtx.lineTo(x, y);
    });
    specCtx.lineTo(W, H);
    specCtx.closePath();
    specCtx.fill();
    
    // Spectrum line
    specCtx.strokeStyle = "#00ff64";
    specCtx.lineWidth = 1.5;
    specCtx.beginPath();
    dbValues.forEach((db, i) => {
        const x = (i / dbValues.length) * W;
        const y = H - ((Math.min(Math.max(db, minDb), maxDb) - minDb) / (maxDb - minDb)) * H;
        i === 0 ? specCtx.moveTo(x, y) : specCtx.lineTo(x, y);
    });
    specCtx.stroke();
}

// Poll every 200ms for smooth animation
setInterval(fetchSpectrum, 200);
fetchSpectrum();
</script>

</body>
</html>
