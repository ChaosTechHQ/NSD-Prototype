// ═══════════════════════════════════════════
//  RF SPECTRUM — clean v2
// ═══════════════════════════════════════════
var _specCanvas = document.getElementById('rfCanvas');
var _specCtx    = _specCanvas ? _specCanvas.getContext('2d') : null;

function drawSpectrum(freqs, powers, peaks) {
  if (!_specCtx || !freqs || freqs.length < 2) return;
  var W = _specCanvas.width;   // real pixel width  (900)
  var H = _specCanvas.height;  // real pixel height (120)
  var PAD_L = 36, PAD_B = 16, PAD_R = 4, PAD_T = 6;
  var plotW = W - PAD_L - PAD_R;
  var plotH = H - PAD_T - PAD_B;

  _specCtx.clearRect(0, 0, W, H);

  var minP = Math.min.apply(null, powers);
  var maxP = Math.max.apply(null, powers);
  if (maxP === minP) { maxP = minP + 1; }
  var minF = freqs[0], maxF = freqs[freqs.length-1];
  if (maxF === minF) { maxF = minF + 1; }

  function px(f) { return PAD_L + ((f - minF) / (maxF - minF)) * plotW; }
  function py(p) { return PAD_T + (1 - (p - minP) / (maxP - minP)) * plotH; }

  // Grid
  _specCtx.save();
  _specCtx.strokeStyle = 'rgba(0,255,80,0.12)';
  _specCtx.lineWidth = 1;
  _specCtx.setLineDash([2, 5]);
  [0, 0.25, 0.5, 0.75, 1].forEach(function(t) {
    var y = PAD_T + t * plotH;
    _specCtx.beginPath(); _specCtx.moveTo(PAD_L, y); _specCtx.lineTo(W - PAD_R, y); _specCtx.stroke();
  });
  [0, 0.25, 0.5, 0.75, 1].forEach(function(t) {
    var x = PAD_L + t * plotW;
    _specCtx.beginPath(); _specCtx.moveTo(x, PAD_T); _specCtx.lineTo(x, PAD_T + plotH); _specCtx.stroke();
  });
  _specCtx.setLineDash([]);
  _specCtx.restore();

  // dB labels (left) — only 3 labels to avoid overlap
  _specCtx.save();
  _specCtx.fillStyle = 'rgba(0,220,80,0.75)';
  _specCtx.font = '9px monospace';
  _specCtx.textAlign = 'right';
  [0, 0.5, 1].forEach(function(t) {
    var db  = maxP - t * (maxP - minP);
    var y   = PAD_T + t * plotH;
    _specCtx.fillText(db.toFixed(0), PAD_L - 2, y + 3);
  });
  _specCtx.restore();

  // Freq labels (bottom) — only 3 labels, well clear of bottom edge
  _specCtx.save();
  _specCtx.fillStyle = 'rgba(0,220,80,0.75)';
  _specCtx.font = '9px monospace';
  _specCtx.textAlign = 'center';
  [0, 0.5, 1].forEach(function(t) {
    var f = minF + t * (maxF - minF);
    var x = PAD_L + t * plotW;
    _specCtx.fillText(f.toFixed(1) + 'M', x, H - 3);
  });
  _specCtx.restore();

  // Fill under curve
  _specCtx.save();
  var grad = _specCtx.createLinearGradient(0, PAD_T, 0, PAD_T + plotH);
  grad.addColorStop(0, 'rgba(0,255,80,0.22)');
  grad.addColorStop(1, 'rgba(0,255,80,0)');
  _specCtx.fillStyle = grad;
  _specCtx.beginPath();
  _specCtx.moveTo(px(freqs[0]), PAD_T + plotH);
  freqs.forEach(function(f, i) { _specCtx.lineTo(px(f), py(powers[i])); });
  _specCtx.lineTo(px(freqs[freqs.length-1]), PAD_T + plotH);
  _specCtx.closePath();
  _specCtx.fill();
  _specCtx.restore();

  // Signal line
  _specCtx.save();
  _specCtx.strokeStyle = '#00ff55';
  _specCtx.lineWidth = 1.5;
  _specCtx.beginPath();
  freqs.forEach(function(f, i) {
    i === 0 ? _specCtx.moveTo(px(f), py(powers[i])) : _specCtx.lineTo(px(f), py(powers[i]));
  });
  _specCtx.stroke();
  _specCtx.restore();

  // Peak markers
  if (peaks && peaks.length) {
    _specCtx.save();
    _specCtx.fillStyle = '#ffee00';
    _specCtx.font = 'bold 8px monospace';
    _specCtx.textAlign = 'center';
    var lastX = -99;
    peaks.forEach(function(p) {
      if (p.freq_mhz == null) return;
      var x = px(p.freq_mhz);
      var y = py(p.power_db != null ? p.power_db : maxP);
      _specCtx.beginPath();
      _specCtx.moveTo(x, y); _specCtx.lineTo(x-4, y+7); _specCtx.lineTo(x+4, y+7);
      _specCtx.closePath(); _specCtx.fill();
      // Only label if not overlapping last label
      if (Math.abs(x - lastX) > 40) {
        _specCtx.fillText(p.freq_mhz.toFixed(1)+'M', x, y - 4);
        lastX = x;
      }
    });
    _specCtx.restore();
  }
}

async function updateSpectrum() {
  try {
    var API = (typeof API_PSD !== 'undefined') ? API_PSD : 'http://10.0.0.153:8000/api/spectrum';
    var url  = API + (API.indexOf('?') === -1 ? '?center_mhz=1090&span_mhz=2' : '');
    var resp = await fetch(url);
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    var data = await resp.json();
    var dbArr = data.spectrum_db || data.points || [];
    var center = data.center_mhz || 1090.0;
    var span   = data.span_mhz   || 2.0;
    var freqs, powers;
    if (dbArr.length && typeof dbArr[0] === 'object') {
      freqs  = dbArr.map(function(p){ return p.freq_mhz; });
      powers = dbArr.map(function(p){ return p.power_db; });
    } else {
      var start = center - span/2;
      var step  = dbArr.length > 1 ? span/(dbArr.length-1) : 0;
      freqs  = dbArr.map(function(_,i){ return start + i*step; });
      powers = dbArr;
    }
    drawSpectrum(freqs, powers, data.peaks || []);
    var nf = document.getElementById('noiseFloor');
    if (nf) nf.textContent = 'Noise floor: ' + (data.noise_floor_db != null ? data.noise_floor_db.toFixed(1) : '--') + ' dB';
    var ab = document.getElementById('activeBand');
    if (ab && data.active_band) ab.textContent = '◉ SCANNING: ' + data.active_band;
  } catch(e) {
    console.warn('Spectrum fetch:', e.message);
  }
}
setInterval(updateSpectrum, 5000);
updateSpectrum();

