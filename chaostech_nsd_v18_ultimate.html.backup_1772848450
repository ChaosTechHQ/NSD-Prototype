<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#000; color:#00ff41; font-family:'Courier New',monospace; font-size:12px; height:100vh; overflow:hidden; }
.top-banner { background:#cc0000; color:#fff; text-align:center; padding:6px; font-weight:bold; font-size:13px; letter-spacing:2px; }
