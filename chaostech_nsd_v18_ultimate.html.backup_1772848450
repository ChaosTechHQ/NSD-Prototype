<script>
var API_BASE = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
  ? 'http://10.0.0.153:8000'
  : 'http://10.0.0.153:8000';
      var RF_BASE  = 'http://10.0.0.153:8000';
var RF_Base = 'http://10.0.0.153:8000';
var _prevBand = null;
var threats = [], systemState = {}, missionState = {}, autonomousMode = {}, rfSpectrum = {};
var NSD_TOKEN = "";
// Fetch token from local API on load — never hardcoded
fetch('http://10.0.0.153:8000/api/token')
  .then(function(r){ return r.json(); })
  .then(function(d){ NSD_TOKEN = d.token || ""; })
  .catch(function(){ console.warn('Token fetch failed — POST endpoints will reject'); });
var noiseFloorDb = null, activeBandName = "";
var _autonomousDirty = 0;  // timestamp of last user interaction
var systemActive = false, currentMode = 'RF_JAM';

var canvas = document.getElementById('radar');
var ctx = canvas.getContext('2d');
var sweep = 0;

function resize() {
  var left = canvas.parentElement;
  var bottom = left.querySelector('.bottom');
  canvas.width = left.clientWidth;
  canvas.height = left.clientHeight - bottom.offsetHeight;
}
window.addEventListener('resize', resize);
resize();

function drawRadar() {
  var W = canvas.width, H = canvas.height;
  var cx = W/2, cy = H/2;
  var R = Math.min(W,H) * 0.44;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#000a00';
  ctx.fillRect(0,0,W,H);
  for (var i=1; i<=4; i++) {
    var r = (R/4)*i;
    ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2);
    ctx.strokeStyle = 'rgba(0,80,0,0.5)'; ctx.lineWidth=1; ctx.stroke();
    ctx.fillStyle='#004400'; ctx.font='10px Courier New';
    ctx.fillText(((i/4)*2.5).toFixed(1)+'km', cx+r+3, cy+4);
  }
  ctx.strokeStyle='rgba(0,60,0,0.5)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(cx,cy-R); ctx.lineTo(cx,cy+R); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx-R,cy); ctx.lineTo(cx+R,cy); ctx.stroke();
  sweep = (sweep+0.025) % (Math.PI*2);
  ctx.save(); ctx.translate(cx,cy); ctx.rotate(sweep);
  var g = ctx.createLinearGradient(0,0,R,0);
  g.addColorStop(0,'rgba(0,255,65,0.5)'); g.addColorStop(1,'rgba(0,255,65,0)');
  ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,R,-0.25,0); ctx.closePath();
  ctx.fillStyle=g; ctx.fill();
  ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(R,0);
  ctx.strokeStyle='rgba(0,255,65,0.9)'; ctx.lineWidth=2; ctx.stroke();
  ctx.restore();
  ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2); ctx.fillStyle='#ff4444'; ctx.fill();
  threats.forEach(function(t) {
    var a = (t.bearing||0)*Math.PI/180;
    var pr = (Math.min(t.range||0.5,2.5)/2.5)*R;
    var px = cx+Math.sin(a)*pr, py = cy-Math.cos(a)*pr;
    var sc = t.threat_score||50;
    var BAND_COLORS = {'433MHz':'#FFD700','900MHz':'#FF4444','ADS-B':'#00FF41','2.4GHz':'#00BFFF','UNK':'#FFA500'};
    var STATE_COLORS = {'NEUTRALIZED':'#ff0000','ENGAGED':'#ffaa00','DETECTED':'#00ff41'};
    var col = STATE_COLORS[t.state] || BAND_COLORS[t.band] || (sc>70?'#ff4444':sc>40?'#ffaa00':'#00ff41');
    ctx.beginPath(); ctx.arc(px,py,9,0,Math.PI*2);
    ctx.strokeStyle=col; ctx.lineWidth=0.5; ctx.stroke();
    ctx.beginPath(); ctx.arc(px,py,5,0,Math.PI*2);
    ctx.fillStyle=col; ctx.fill();
    ctx.fillStyle='#00ff41'; ctx.font='bold 9px Courier New';
    ctx.fillText(t.id, px+7, py-2);
  });
  requestAnimationFrame(drawRadar);
}
drawRadar();

const API_BASE  = 'http://127.0.0.1:8000';
const NSD_TOKEN = 'change-me';

const API_PSD = "http://10.0.0.153:8000/api/spectrum";
// ── Live RF Spectrum (NSD RF Bridge) ─────────────────────────
let rfFetching = false;


function fetchRF() { return; // v19: use /api/spectrum

  fetch(RF_BASE + '/api/psd_scan')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.points || data.points.length === 0) return;
      var freqs  = data.points.map(function(p) { return p.freq_mhz; });
      var powers = data.points.map(function(p) { return p.power_db; });
      drawSpectrum(freqs, powers, data.peaks || []);
    })
    .catch(function(e) { console.warn('RF fetch:', e.message); });
}

setInterval(fetchRF, 2000);
fetchRF();

function fetchData() {
  fetch(API_BASE+'/api/hardware')
    .then(function(r){ return r.json(); })
    .then(function(d) {
      var _newThreats = (d.threats||[]).map(function(t) {
        if (t.frequency && !t.freq) {
          t.freq = parseFloat(t.frequency.split(' ')[0]) / 1000;
        }
        t.freq = t.freq || 0;
        t.speed = t.speed || (Math.floor(Math.random()*15)+10);
        t.altitude = t.altitude || (Math.floor(Math.random()*100)+50);
        return t;
      });
      if (_newThreats.length > 0) threats = _newThreats;
      systemState = d.system_state || {};
      noiseFloorDb = (d.noise_floor_db !== undefined && d.noise_floor_db !== null) ? d.noise_floor_db : noiseFloorDb;
      activeBandName = d.active_band || null;
      if (activeBandName && _prevBand && activeBandName !== _prevBand) {
        var el = document.getElementById('tCount');
        if (el) {
          el.classList.remove('band-switching');
          void el.offsetWidth;
          el.classList.add('band-switching');
          setTimeout(function(){ el.classList.remove('band-switching'); }, 1600);
        }
      }
      _prevBand = activeBandName;
      missionState = d.mission_state || {};
      autonomousMode = d.autonomous_mode || {};
      rfSpectrum = d.rf_spectrum || {};
      systemActive = systemState.active || false;
      currentMode = systemState.mode || 'RF_JAM';
      if(typeof updateUI === "function") updateUI();
    })
    .catch(function(e){ console.warn('Bridge offline:', e.message); });
}

function toggleSystem() {
  systemActive = !systemActive;
  updateUI();

  fetch(API_BASE + '/api/control', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-NSD-Token': NSD_TOKEN
    },
    body: JSON.stringify({
      active: systemActive,
      mode: currentMode
    })
  }).catch(function(e){
    console.warn('control API error:', e.message);
  });
}

function setMode(mode, el) {
  currentMode = mode;
  document.querySelectorAll('.mbtn').forEach(function(b){ b.classList.remove('on'); });
  if (el) el.classList.add('on');
  document.getElementById('sDisrupt').textContent = mode;
  currentMode = mode;
  document.querySelectorAll('.mbtn').forEach(function(b){ b.classList.remove('on'); });
  if (el) el.classList.add('on');
  fetch(API_BASE+'/api/control', {
    method:'POST',
    headers:{'Content-Type':'application/json','X-NSD-Token':NSD_TOKEN},
    body:JSON.stringify({mode:mode})
  }).catch(function(){});
  
}

function updateAutonomous() {
  _autonomousDirty = Date.now();
  var en = document.getElementById('aiEn').checked;
  var au = document.getElementById('aiAuto').checked;
  var th = parseInt(document.getElementById('thrSlider').value);
  document.getElementById('thrVal').textContent = th;
  fetch(API_BASE+'/api/control', {
    method:'POST',
    headers:{'Content-Type':'application/json','X-NSD-Token':NSD_TOKEN},
    body:JSON.stringify({autonomous_enabled:en,auto_engage:au,threat_threshold:th})
  }).catch(function(){});
}

function fmtTime(s) {
  s = s||0;
  return Math.floor(s/3600)+':'+String(Math.floor((s%3600)/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');
}

function updateUI() {
  document.getElementById('sMode').textContent = systemActive ? 'ACTIVE' : 'STANDBY';
  document.getElementById('sDisrupt').textContent = currentMode;
  var pwr = systemState.power_level||100;
  document.getElementById('sPower').textContent = pwr+'%';
  var nrg = systemState.energy_reserves||100;
  document.getElementById('eBar').style.width = nrg+'%';
  document.getElementById('eBar').innerHTML = '<span>'+nrg+'%</span>';
  var btn = document.getElementById('toggleBtn');
  btn.textContent = systemActive ? 'DEACTIVATE SYSTEM' : 'ACTIVATE SYSTEM';
  btn.className = systemActive ? 'btn btn-active' : 'btn';
  if (autonomousMode.enabled !== undefined) {
    if (Date.now() - _autonomousDirty > 5000) document.getElementById('aiEn').checked = autonomousMode.enabled;
    if (Date.now() - _autonomousDirty > 5000) document.getElementById('aiAuto').checked = autonomousMode.auto_engage||false;
    var th = autonomousMode.threat_threshold||70;
    if (Date.now() - _autonomousDirty > 5000) {
      document.getElementById('thrSlider').value = th;
      var lbl = document.getElementById('thrLabel');
      if (lbl) lbl.textContent = th;
    }
    document.getElementById('thrVal').textContent = th;
  }
  var ms = missionState || {};
  // Uptime: client-side timer only (see _pageStart setInterval above)
  // Unique RF Sources
  document.getElementById('mTD').textContent = ms.threats_detected || threats.length || 0;
  // Threats Engaged = threats with score >= 70
  var engaged = threats.filter(function(t){ return (t.threat_score||0) >= 70; }).length;
  document.getElementById('mTE').textContent = engaged;
  // Swarms
  document.getElementById('mSE').textContent = ms.swarms_eliminated || 0;
  document.getElementById('mTE').textContent = ms.threats_engaged||0;
  document.getElementById('mTN').textContent = ms.threats_neutralized||0;
  
  // Swarm alert
  var ms2 = missionState || {};
  var activeSwarms = ms2.active_swarms || 0;
  var swarmEl = document.getElementById('swarmAlert');
  if (swarmEl) swarmEl.style.display = activeSwarms > 0 ? 'block' : 'none';
  document.getElementById('mSD').textContent = ms2.swarms_detected || 0;

  // legacy fallback
  // document.getElementById('mSD').textContent = ms.swarms_detected||0;
  document.getElementById('mSE').textContent = ms.swarms_eliminated||0;
  document.getElementById('mAA').textContent = ms.autonomous_actions||0;
  var bands = (rfSpectrum&&rfSpectrum.bands)?rfSpectrum.bands:{};
  var tot = Math.max(rfSpectrum.total||1,1);
  var sets = [['rfb1','rfc1',bands['433']||0],['rfb2','rfc2',bands['900']||0],['rfb3','rfc3',bands['2.4']||0],['rfb4','rfc4',bands['other']||0]];
  sets.forEach(function(s){ document.getElementById(s[0]).style.width=Math.round((s[2]/tot)*100)+'%'; document.getElementById(s[1]).textContent=s[2]; });
  var nfEl = document.getElementById('noiseFloor');
  if (nfEl) nfEl.textContent = 'Noise floor: ' + (noiseFloorDb !== null ? noiseFloorDb.toFixed(1) : '--') + ' dB';
  var abEl = document.getElementById('activeBand');
  if (abEl && activeBandName) abEl.textContent = '◉ SCANNING: ' + activeBandName;
  document.getElementById('tCount').textContent = threats.length;
  document.getElementById('tList').innerHTML = threats.map(function(t) {
    var sc  = t.threat_score||0;
    var cls = sc>70?'hi':sc>40?'md':'';
    var scCls = sc>70?'sc-hi':sc>40?'sc-md':'sc-lo';
    var state = t.state||'DETECTED';
    var stateColor = state==='NEUTRALIZED'?'#ff4444':state==='ENGAGED'?'#ffaa00':'#00ff41';
    var stateIcon  = state==='NEUTRALIZED'?'[NEUTRALIZED]':state==='ENGAGED'?'[ENGAGED]':t.swarm_member?'[SWARM]':'[DETECTED]';
    var barW = Math.min(100, sc);
    var barColor = sc>70?'#ff4444':sc>40?'#ffaa00':'#00ff41';
    return '<div class="threat-card '+cls+'" style="border-left:3px solid '+stateColor+';margin-bottom:6px;padding:6px 8px;">'
      + '<div class="t-hdr"><span class="t-id" style="color:'+stateColor+';">TGT-'+t.id+' '+(t.type||'RF')+'</span>'
      + '<span class="t-score '+scCls+'" style="color:'+stateColor+';">'+sc+'</span></div>'
      + '<div class="t-data" style="color:#aaffaa;">'+t.freq_mhz.toFixed(3)+' MHz | '+t.power_db.toFixed(1)+' dBm | '+t.band+'</div>'
      + '<div class="t-data" style="color:#ffff00;font-size:10px;">'+(t.protocol||t.type)+' — '+(t.confidence||0)+'% confidence</div>'
      + '<div class="t-data" style="color:#888;font-size:9px;font-style:italic;">'+(t.description||'')+'</div>'
      + '<div class="t-data" style="color:'+stateColor+';font-weight:bold;">'+stateIcon+'</div>'
      + '<div style="background:#001a00;border-radius:2px;height:4px;margin-top:4px;">'
      + '<div style="width:'+barW+'%;height:4px;background:'+barColor+';border-radius:2px;transition:width 0.5s;"></div></div>'
      + '</div>';
  }).join('');
}

