}
.threat-card.swarm { border-left-color:#ff0000; background:#1a0000; }

@keyframes bandFlash {
  0%   { color:#00ff41; text-shadow:0 0 6px #00ff41; }
  35%  { color:#ffffff; text-shadow:0 0 20px #fff; }
  100% { color:#00ff41; text-shadow:0 0 6px #00ff41; }
}
.band-switching { animation: bandFlash 0.5s ease 3; }

.t-hdr { display:flex; justify-content:space-between; margin-bottom:2px; }
.t-id { color:#00ff41; font-weight:bold; }
.t-score { padding:1px 5px; border-radius:2px; font-weight:bold; }
.sc-hi { background:#cc0000; color:#fff; }
.sc-md { background:#ff8800; color:#000; }
.sc-lo { background:#006600; color:#fff; }
.t-data { color:#009900; }
.jam-bar { height:4px; background:#001100; border-radius:2px; margin-top:3px; }
.jam-fill { height:100%; background:#ffaa00; border-radius:2px; }
.rf-row { display:flex; align-items:center; gap:6px; margin:3px 0; font-size:10px; }
.rf-lbl { color:#007700; width:55px; }
.rf-bg { flex:1; height:8px; background:#001100; border-radius:2px; }
.rf-fill { height:100%; background:#00ff41; border-radius:2px; transition:width 0.4s; }
.rf-n { color:#00ff41; width:20px; text-align:right; }
.energy-bar { height:16px; background:#001100; border:1px solid #003300; border-radius:2px; overflow:hidden; margin-top:3px; }
.energy-fill { height:100%; background:linear-gradient(90deg,#ff0000,#ffaa00 50%,#00ff41); display:flex; align-items:center; justify-content:center; transition:width 0.5s; }
.energy-fill span { font-size:10px; font-weight:bold; color:#000; }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-thumb { background:#005500; }
</style>

