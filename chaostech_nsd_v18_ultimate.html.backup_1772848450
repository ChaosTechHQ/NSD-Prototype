.mbtn:hover, .mbtn.on { background:#003300; border-color:#00ff41; color:#00ff41; }
.ai-row { display:flex; align-items:center; gap:8px; font-size:11px; margin-bottom:5px; }
.ai-row label { color:#00aa00; }
input[type=checkbox] { accent-color:#00ff41; }
input[type=range] { width:100%; accent-color:#00ff41; margin-top:3px; }
.threat-card { background:#001500; border:1px solid #003300; border-left:3px solid #00ff41; padding:5px 7px; margin:3px 0; font-size:10px; }
.threat-card.hi { border-left-color:#ff4444; }
.threat-card.md { border-left-color:#ffaa00; }
@keyframes swarmPulse {
  0%,100% { opacity:1; color:#ff0000; text-shadow:0 0 20px #ff0000; }
