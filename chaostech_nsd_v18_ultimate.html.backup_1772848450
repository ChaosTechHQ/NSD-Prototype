function initBridge(){ if(document.readyState === "complete") fetchData(); else setTimeout(initBridge, 100); } initBridge();

var _pageStart = Date.now();
setInterval(function() {
  var elapsed = Math.floor((Date.now() - _pageStart) / 1000);
  var h = Math.floor(elapsed / 3600);
  var m = Math.floor((elapsed % 3600) / 60);
  var s = elapsed % 60;
  var fmt = h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
  var el = document.getElementById('uptime');
  if (el) el.textContent = fmt;
}, 1000);

setInterval(fetchData, 2000);
